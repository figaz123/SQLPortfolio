---Q1 & Q2: Base Clean Table
WITH Clean_Customer_ID AS (
  SELECT 
    array_to_string(regexp_extract_all(loan.customer_id, "[a-zA-Z0-9]"), "") AS cln_customer_id,
    loan.loan_id,
    loan.loan_status,
    loan.loan_amount,
    loan.funded_amount,
    loan.term,
    loan.state,
    loan.issue_date,
    loan.issue_year,
    loan.int_rate
  FROM `nextproject-001.FIP.loan` AS loan
  WHERE loan.loan_status IN ('Current', 'In Grace Period', 'Late (31-120 days)','Late (16-30 days)', 'Default')
),

Clean_Customer AS (
  SELECT 
    array_to_string(regexp_extract_all(customer.customer_id, "[a-zA-Z0-9]"), "") AS cln_customer_id,
    customer.home_ownership,
    annual_inc + COALESCE(annual_inc_joint, 0) AS total_combined_income,
    emp_length,
    addr_state
  FROM `nextproject-001.FIP.customer` AS customer
)

-- Q7: Deep Dive Profiling
SELECT
  CASE
    WHEN l.issue_year = 2014 THEN '1. Anomaly Cohort (2014)'
    WHEN l.issue_year = 2019 THEN '2. Benchmark Cohort (2019)'
    ELSE '3. Other Cohorts'
  END AS cohort_segment,
  
  COUNT(DISTINCT l.cln_customer_id) AS total_customers,

  -- a. Home ownership rate (Percentage of OWN or MORTGAGE)
  SUM(CASE WHEN c.home_ownership IN('OWN', 'MORTGAGE') THEN 1 ELSE 0 END) / COUNT(DISTINCT l.cln_customer_id) AS home_ownership_rate,
  
  -- b. Average annual income
  AVG(c.total_combined_income) AS avg_income,
  
  -- c. Lower employment length
  SUM(CASE WHEN c.emp_length = '< 1 year' THEN 1 ELSE 0 END) / COUNT(DISTINCT l.cln_customer_id) AS pct_less_than_1_yr_emp,
  
  -- f. Higher interest rate
  AVG(l.int_rate) AS avg_interest_rate
  
FROM Clean_Customer AS c 
LEFT JOIN Clean_Customer_ID AS l 
  ON l.cln_customer_id = c.cln_customer_id
-- We must filter out NULLs generated by the LEFT JOIN if a customer has no active loans
WHERE l.issue_year IS NOT NULL 
GROUP BY cohort_segment
ORDER BY cohort_segment;
